[
  {
    "id": "test-request-headers",
    "name": "All Request Headers",
    "enabled": true,
    "urlFilter": "||modheader.com",
    "requestHeaders": [
      { "id": "rq-01", "name": "Authorization",    "value": "Bearer test-token-abc123",              "enabled": true },
      { "id": "rq-02", "name": "Content-Type",     "value": "application/json",                      "enabled": true },
      { "id": "rq-03", "name": "Accept",            "value": "application/json, text/html",           "enabled": true },
      { "id": "rq-04", "name": "Origin",            "value": "https://test.example.com",              "enabled": true },
      { "id": "rq-05", "name": "Referer",           "value": "https://test.example.com/page",         "enabled": true },
      { "id": "rq-06", "name": "User-Agent",        "value": "HeaderEditor/1.0 TestAgent",            "enabled": true },
      { "id": "rq-07", "name": "Cookie",            "value": "session=test123; theme=dark",           "enabled": true },
      { "id": "rq-08", "name": "X-Api-Key",         "value": "test-api-key-12345",                    "enabled": true },
      { "id": "rq-09", "name": "X-Auth-Token",      "value": "test-auth-token-xyz",                   "enabled": true },
      { "id": "rq-10", "name": "X-Requested-With",  "value": "XMLHttpRequest",                        "enabled": true },
      { "id": "rq-11", "name": "X-CSRF-Token",      "value": "test-csrf-token-789",                   "enabled": true },
      { "id": "rq-12", "name": "X-Forwarded-For",   "value": "192.168.1.100",                         "enabled": true },
