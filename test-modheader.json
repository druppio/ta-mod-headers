      { "id": "rq-24", "name": "Sec-Fetch-Mode",    "value": "navigate",                              "enabled": true },
      { "id": "rq-25", "name": "Sec-Fetch-Site",    "value": "none",                                  "enabled": true },
      { "id": "rq-26", "name": "Sec-Fetch-Dest",    "value": "document",                              "enabled": true },
      { "id": "rq-27", "name": "DNT",               "value": "1",                                     "enabled": true }
    ],
    "responseHeaders": []
  },
  {
    "id": "test-response-headers",
    "name": "All Response Headers",
    "enabled": true,
    "urlFilter": "||modheader.com",
    "requestHeaders": [],
    "responseHeaders": [
      { "id": "rs-01", "name": "Access-Control-Allow-Origin",       "value": "*",                                          "enabled": true },
      { "id": "rs-02", "name": "Access-Control-Allow-Methods",      "value": "GET, POST, PUT, DELETE, OPTIONS",            "enabled": true },
      { "id": "rs-03", "name": "Access-Control-Allow-Headers",      "value": "Content-Type, Authorization",               "enabled": true },
      { "id": "rs-04", "name": "Access-Control-Allow-Credentials",  "value": "true",                                       "enabled": true },
      { "id": "rs-05", "name": "Access-Control-Expose-Headers",     "value": "X-Custom-Header, X-Request-ID",             "enabled": true },
      { "id": "rs-06", "name": "Access-Control-Max-Age",            "value": "86400",                                      "enabled": true },
      { "id": "rs-07", "name": "Content-Security-Policy",           "value": "default-src 'self'",                         "enabled": true },
      { "id": "rs-08", "name": "Content-Security-Policy-Report-Only","value": "default-src 'self'; report-uri /csp-report", "enabled": true },
      { "id": "rs-09", "name": "Referrer-Policy",                   "value": "strict-origin-when-cross-origin",           "enabled": true },
      { "id": "rs-10", "name": "X-Frame-Options",                   "value": "SAMEORIGIN",                                 "enabled": true },
      { "id": "rs-11", "name": "X-Content-Type-Options",            "value": "nosniff",                                    "enabled": true },
      { "id": "rs-12", "name": "Strict-Transport-Security",         "value": "max-age=31536000; includeSubDomains",        "enabled": true },
      { "id": "rs-13", "name": "Permissions-Policy",                "value": "geolocation=(), camera=()",                  "enabled": true },
      { "id": "rs-14", "name": "Cache-Control",                     "value": "no-store, max-age=0",                        "enabled": true },
      { "id": "rs-15", "name": "X-XSS-Protection",                  "value": "1; mode=block",                              "enabled": true },
      { "id": "rs-16", "name": "Vary",                              "value": "Accept-Encoding, Origin",                    "enabled": true },
      { "id": "rs-17", "name": "ETag",                              "value": "\"test-etag-abc123\"",                        "enabled": true },
      { "id": "rs-18", "name": "Last-Modified",                     "value": "Thu, 01 Jan 2026 00:00:00 GMT",              "enabled": true },
      { "id": "rs-19", "name": "Server",                            "value": "HeaderEditor-Test/1.0",                      "enabled": true },
      { "id": "rs-20", "name": "X-Powered-By",                      "value": "HeaderEditor",                               "enabled": true }
    ]
  }
]
